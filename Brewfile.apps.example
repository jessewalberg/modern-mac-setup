# Copy this file to Brewfile.apps, then uncomment only selected applications.
# Install the reviewed file with:
#   ./scripts/bootstrap.sh --apps Brewfile.apps
#
# Homebrew casks install vendor applications and have a different trust model
# from Homebrew formulae. Review the vendor, license, permissions, data use,
# account requirements, and update channel before uncommenting a line.

# Password manager — choose one.
# cask "1password"
# cask "bitwarden"

# Browser — Safari is built in. Choose one stable browser to start.
# Release-preview channels, deprecated casks, and regional anti-detect browsers
# are intentionally omitted.
#
# Mainstream browser families.
# cask "google-chrome"
# cask "firefox"
# cask "brave-browser"
# cask "microsoft-edge"
# cask "vivaldi"
# cask "opera"
#
# macOS-focused and alternative interfaces.
# cask "arc"
# cask "orion"
# cask "duckduckgo"
# cask "zen"
#
# Privacy and security-focused alternatives.
# cask "floorp"
# cask "waterfox"
# cask "tor-browser"
# cask "mullvad-browser"
# cask "ungoogled-chromium"
# cask "aloha-browser"
#
# AI and workspace browsers.
# cask "thebrowsercompany-dia"
# cask "comet"
# cask "chatgpt-atlas"  # Apple silicon and macOS 14+
# cask "browseros"
# cask "sigmaos"
# cask "wavebox"
#
# Specialized browsers.
# cask "opera-gx"
# cask "opera-air"
# cask "responsively"  # responsive web-development testing
# cask "blisk"         # developer-oriented browser

# Communication and community — a browser is enough for occasional access.
# cask "discord"
# cask "slack"

# Screenshots — macOS shortcuts are sufficient for basic capture.
# cask "macshot"  # open-source capture, annotation, OCR, scrolling, and recording

# Voice dictation — macOS dictation is built in; add this only for local models.
# cask "opensuperwhisper"  # open source; macOS 14+ on Apple silicon

# Clipboard history can retain passwords, tokens, and other copied secrets.
# cask "maccy"  # open-source clipboard manager; configure exclusions carefully

# Local databases are stateful. Prefer project containers for disposable data,
# and install only the engines required by active projects.
# brew "postgresql@18"  # PostgreSQL server and psql; versioned and keg-only
# brew "sqlite"         # newer sqlite3 than macOS provides; keg-only
# brew "mysql"
# brew "mariadb"        # conflicts with MySQL; choose one
# brew "duckdb"         # embedded analytical SQL database
# brew "valkey"         # open-source Redis-compatible server
# brew "redis"          # use when a project specifically requires Redis
# brew "mongosh"        # MongoDB shell/client only
#
# MongoDB Server is not in Homebrew core. Prefer a project container or review
# MongoDB's official vendor tap separately instead of hiding a tap in this file.

# Database clients — start with one broad client, then add a specialized client
# only when it provides a feature the broad client does not.
# cask "dbeaver-community"       # broad open-source SQL client
# cask "beekeeper-studio"        # approachable cross-database SQL client
# cask "dbgate"                  # open-source SQL and MongoDB client
# cask "tableplus"               # native commercial multi-database client
# cask "datagrip"                # JetBrains commercial database IDE
# cask "pgadmin4"                # PostgreSQL-specific administration
# cask "mongodb-compass"         # MongoDB-specific GUI
# cask "db-browser-for-sqlite"   # SQLite-specific GUI
# cask "redis-insight"           # Redis and Valkey GUI

# API clients — choose one. Collections and environments may contain secrets,
# tokens, cookies, production URLs, and request history.
# cask "postman"
# cask "insomnia"
# cask "bruno"          # open source; file-based, Git-friendly collections
# cask "yaak"           # REST, GraphQL, and gRPC
# cask "hoppscotch"     # open-source API development client
# cask "httpie-desktop" # REST, GraphQL, and HTTP desktop client

# Editor or visual agent workspace — choose one, or keep your current editor.
# cask "visual-studio-code"
# cask "zed"
# cask "cursor"
# cask "antigravity"

# Terminal coding agent — choose zero or one to start.
# Review workspace trust, command approval, data use, and update ownership.
# cask "claude-code"      # command: claude; Homebrew stable channel
# cask "codex"            # command: codex
# cask "copilot-cli"      # command: copilot; requires GitHub Copilot access
# cask "antigravity-cli"  # command: agy
# cask "cursor-cli"       # command: cursor-agent; currently beta
# brew "opencode"         # command: opencode; Homebrew core may lag upstream
#
# Pi is an extensible agent harness distributed through npm, not Homebrew:
# npm install -g --ignore-scripts @earendil-works/pi-coding-agent
# Command: pi
#
# Aider is intentionally installed in an isolated uv tool environment; see
# docs/REFERENCE.md#ai-coding-tools.

# Terminal workspace — Terminal.app is sufficient for bootstrap.
# cask "cmux"     # workspace for terminals, agents, and browser panes
# cask "ghostty"  # focused standalone terminal
# cask "iterm2"   # mature terminal with extensive profiles and integrations

# Containers — choose one platform after checking licensing and team needs.
# cask "docker-desktop"
# cask "orbstack"
# cask "podman-desktop"
#
# Lightweight open-source alternative to a container desktop. Uncomment all
# three formulae together; do not combine this stack with Docker Desktop.
# brew "colima"
# brew "docker"
# brew "docker-compose"  # command: docker-compose; `docker compose` needs plugin config

# Window management / launcher — both require meaningful permissions.
# cask "rectangle"
# cask "raycast"

# Dotfile management is useful once configuration grows.
# brew "chezmoi"

# Mac App Store automation is intentionally not enabled by default.
# brew "mas"
