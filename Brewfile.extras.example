# Optional formulae, agents, and role-specific developer tools.
#
# Nothing in this file is installed by default. Copy it to the ignored local
# overlay, uncomment only reviewed choices, and apply it directly:
#
#   cp Brewfile.extras.example Brewfile.local
#   ${EDITOR:-nano} Brewfile.local
#   brew bundle check --file=Brewfile.local --no-upgrade
#   brew bundle install --file=Brewfile.local --no-upgrade
#
# Read docs/tool-catalog.md before selecting tools. Prefer one owner per
# responsibility and keep project versions in project configuration when
# possible.

# Richer file and directory navigation.
# brew "eza"       # Modern directory listings; keep basic ls knowledge.
# brew "zoxide"    # Frecency-based directory jumping; requires shell init.

# Git and shell workflow.
# brew "git-delta" # Syntax-highlighted Git and diff pager; requires Git config.
# brew "lazygit"   # Terminal UI for Git operations.
# brew "direnv"    # Loads reviewed .envrc files by directory.
# brew "atuin"     # Structured searchable shell history; review sync/privacy.
# brew "starship"  # Cross-shell prompt; requires shell init and configuration.
# brew "tmux"      # Persistent terminal sessions and multiplexing.
# brew "just"      # Project command runner using a committed justfile.
# brew "watchexec" # Rerun commands when files change.

# Data formats and HTTP.
# brew "yq"        # Query and transform YAML.
# brew "xh"        # Concise HTTP client; keep curl knowledge.
# brew "httpie"    # Human-readable HTTP client.

# Diagnostics and benchmarking.
# brew "btop"      # Interactive process and resource monitor.
# brew "dust"      # Visual disk-usage summary.
# brew "duf"       # Readable mounted-filesystem overview.
# brew "hyperfine" # Repeated command benchmarking with warmups.
# brew "tealdeer"  # Concise community command examples.

# Terminal editors — choose only when their editing model is wanted.
# brew "neovim"
# brew "helix"

# Dotfile management — choose one after configuration has grown.
# brew "chezmoi"
# brew "yadm"
# brew "stow"

# AI coding agents — start with one and review repository access, command
# approval, sandboxing, model/provider data handling, credentials, and billing.
# cask "claude-code"
# cask "codex"
# brew "opencode"
# brew "aider"

# Multi-agent orchestration — add only after a real parallel-work need exists.
# brew "claude-squad"
# cask "conductor"
# cask "openusage" # Local usage overview; inspect what metadata it reads.

# Command-line container engines — choose one primary local container owner.
# brew "colima"    # Linux VM for container runtimes; pair with reviewed clients.
# brew "podman"    # OCI containers through a Podman machine on macOS.

# Kubernetes and infrastructure — normally project- or team-pinned.
# brew "kubectl"
# brew "k9s"
# brew "helm"
# brew "opentofu"

# Cloud CLIs — install only for the cloud accounts and teams actually used.
# brew "awscli"
# cask "gcloud-cli"

# Network and local-service utilities.
# brew "ngrok"     # Public tunnels; understand authentication and exposure.
# brew "mkcert"    # Locally trusted development certificates.

# Media and document processing — project-specific rather than baseline.
# brew "ffmpeg"
# brew "imagemagick"
# brew "pandoc"
# brew "poppler"
